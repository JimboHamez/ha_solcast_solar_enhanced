__pycache__/
*.pyc
*.pyo
.coverage
htmlcov/

# Tooling caches (pytest / mypy / ruff) — match at any depth, incl. the
# custom_components/.mypy_cache/ that lands inside the tracked package.
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local virtual environments (scan.sh creates .venv; venv/ is the dev env)
.venv/
venv/

# Local working docs
*.docx
COMMUNITY_ANNOUNCEMENT.md
COMMUNITY_REPLY.md

# Local-only PV-tuning / notebook-comparison sandbox (never pushed)
testing/

# Local-only analysis scratch (CSVs, docx, runbooks) — never pushed
analysis/

# SQLite databases and their WAL/SHM sidecars (never commit data)
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Local history exports / imports (e.g. node-red CSVs) — user data, never pushed
data/

# Generated analysis/CSV outputs from the tools/ scripts — regenerable, not pushed
analysis/

# Local-only tests that depend on the git-ignored data/ fixtures
tests/test_sites_fixtures.py

# MCP server config — contains a Context7 API key, never commit
.mcp.json
